@page
@model ErrorModel
@{
    ViewData["Title"] = "错误";
}

<h1 class="text-danger">发生错误</h1>
<h2 class="text-danger">处理请求时出现问题。</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>请求编号：</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>开发模式</h3>
<p>
    切换到 <strong>Development</strong> 环境后，会显示更详细的错误信息。
</p>
<p>
    <strong>部署后的应用不应启用 Development 环境。</strong>
    该环境可能会向最终用户显示异常中的敏感信息。
    本地调试时，可以将 <strong>ASPNETCORE_ENVIRONMENT</strong> 环境变量设置为 <strong>Development</strong> 后重启应用。
</p>
