@page
@model IndexModel
@{
    ViewData["Title"] = "足底热力图分析";
}

<section class="hero">
    <div>
        <p class="eyebrow">开源 ASP.NET Core 辅助筛查演示</p>
        <h1>足底热力图分析</h1>
        <p class="hero-copy">解析足底压力或温度传感器数据，展示左右足热力图，并输出透明、可解释的辅助筛查结果。</p>
    </div>
    <form method="post" enctype="multipart/form-data" class="input-panel">
        <label for="ScanFile">导入扫描文件</label>
        <input asp-for="ScanFile" id="ScanFile" type="file" class="form-control" accept=".bin,.dat,.hex,.txt,.b64,.base64" />
        <label for="ScanText">粘贴十六进制、二进制位串或 Base64 数据</label>
        <textarea asp-for="ScanText" id="ScanText" rows="5" class="form-control" placeholder="@Model.SampleHex"></textarea>
        <div class="actions">
            <button type="submit" class="btn btn-primary">开始分析</button>
            <button type="button" class="btn btn-outline-secondary" id="loadSample">加载示例</button>
        </div>
        <p class="format-note">`.bin`/`.dat` 按原始字节解析，`.hex`/`.txt`/`.b64`/`.base64` 按文本解析。格式：第 0 字节为宽度，第 1 字节为高度，随后依次为左足矩阵和右足矩阵，每个点 1 字节。</p>
    </form>
</section>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-warning" role="alert">@Model.ErrorMessage</div>
}

<section class="workspace" data-heatmap='@Html.Raw(Model.HeatmapJson)' data-sample="@Model.SampleHex">
    <div class="heatmap-area">
        <div class="heatmap-card">
            <div class="panel-heading">
                <h2>左足</h2>
                <span>@Model.Scan?.LeftFoot.Width x @Model.Scan?.LeftFoot.Height</span>
            </div>
            <canvas id="leftHeatmap" width="360" height="540"></canvas>
        </div>
        <div class="heatmap-card">
            <div class="panel-heading">
                <h2>右足</h2>
                <span>@Model.Scan?.RightFoot.Width x @Model.Scan?.RightFoot.Height</span>
            </div>
            <canvas id="rightHeatmap" width="360" height="540"></canvas>
        </div>
    </div>

    @if (Model.Report is not null)
    {
        <aside class="analysis-panel">
            <div class="summary-grid">
                <div>
                    <span>足弓类型</span>
                    <strong>@Model.Report.ArchType</strong>
                </div>
                <div>
                    <span>步态周期</span>
                    <strong>@Model.Report.GaitCycle</strong>
                </div>
                <div>
                    <span>重心平衡</span>
                    <strong>@Model.Report.CenterOfPressure</strong>
                </div>
            </div>
            <div class="findings">
                @foreach (var finding in Model.Report.Findings)
                {
                    <article>
                        <div>
                            <span class="level">@finding.Level</span>
                            <h3>@finding.Category</h3>
                        </div>
                        <p>@finding.Summary</p>
                        <small>@finding.Rationale</small>
                    </article>
                }
            </div>
            <p class="disclaimer">@Model.Report.Disclaimer</p>
        </aside>
    }
</section>
